{
  "name": "artillery-plugin-apdex",
  "version": "1.24.0",
  "description": "Calculate and report Apdex scores",
  "main": "index.ts",
  "scripts": {
    "test": "tap ./test/*.spec.js --timeout 300"
  },
  "tap": {
    "disable-coverage": true,
    "allow-empty-coverage": true,
    "color": true,
    "test-env": [
      "ARTILLERY_TELEMETRY_DEFAULTS={\"source\":\"test-suite\"}"
    ],
    "plugin": [
      "!@tapjs/typescript"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MPL-2.0",
  "devDependencies": {
    "tap": "^19.2.5"
  },
  "type": "module"
}
