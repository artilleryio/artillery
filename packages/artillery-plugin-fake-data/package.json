{
  "name": "artillery-plugin-fake-data",
  "version": "1.24.0",
  "description": "Add fake test data easily to your Artillery test scripts.",
  "main": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "tap ./test/*.spec.js --timeout 120"
  },
  "tap": {
    "disable-coverage": true,
    "allow-empty-coverage": true,
    "color": true,
    "plugin": [
      "!@tapjs/typescript"
    ]
  },
  "license": "MPL-2.0",
  "dependencies": {
    "@faker-js/faker": "10.4.0"
  },
  "devDependencies": {
    "tap": "^19.0.2"
  }
}
