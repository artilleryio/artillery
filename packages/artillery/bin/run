#!/usr/bin/env node

/* This Source Code Form is subject to the terms of the Mozilla Public
 * License, v. 2.0. If a copy of the MPL was not distributed with this
 * file, You can obtain one at http://mozilla.org/MPL/2.0/. */

// NOTE: this launcher runs the built output in ../dist. Run
// `npm run build` after cloning the repo or pulling changes.

import { flush, handle, run, settings } from '@oclif/core';

// The repo root carries a tsconfig.json (native type-stripping setup).
// Without this switch oclif detects it and remaps command paths through
// its TypeScript dev-mode (ts-node), which breaks relative path
// resolution.
settings.enableAutoTranspile = false;

import { createGlobalObject } from '../dist/lib/artillery-global.js';

import banner from '../dist/lib/cli/banner.js';
import { rainbow } from '../dist/lib/util.js';
import setupConsoleCapture from '../dist/lib/console-capture.js';

async function main() {
  await createGlobalObject();
  await setupConsoleCapture();

  if (!process.argv.slice(2).length) {
    console.log(Math.random() * 100 > 34 ? banner : rainbow(banner));
  } else if (
    process.argv.slice(2).length === 1 &&
    process.argv.slice(2)[0] === '-V'
  ) {
    process.argv[2] = 'version';
  }

  // import.meta.url tells oclif where to find the CLI's package.json
  // (in CJS it derived this from require.main)
  run(process.argv.slice(2), import.meta.url).then(flush).catch(handle);
}

main();
